{
	"name": "selective-hearing-supply",
	"compatibility_date": "2026-04-12",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"kv_namespaces": [
		{
