---
interface Props {
  title: string;
  activeNav?: 'products' | 'links' | 'emails' | 'settings';
}
const { title, activeNav } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon-admin.svg" />
    <title>{title} — SH Supply Admin</title>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@700&display=swap" />
    <meta name="robots" content="noindex,nofollow" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #0D0D0D; color: #F5F5F0; font-family: 'Helvetica Neue', system-ui, sans-serif; min-height: 100vh; display: flex; }
      input, textarea, select, button { font-family: inherit; }
    </style>
  </head>
  <body>

    <!-- Sidebar -->
    <aside style="width:220px; min-height:100vh; background:#0D0D0D; border-right:1px solid #2A2A2A; display:flex; flex-direction:column; flex-shrink:0; position:sticky; top:0; height:100vh;">

      <!-- Logo -->
      <div style="padding:24px 20px 20px; border-bottom:1px solid #1E1E1E;">
        <a href="/admin" style="display:flex; align-items:center; gap:8px; text-decoration:none;">
          <div style="width:32px; height:28px; background:#FF7136; display:flex; align-items:center; justify-content:center; border-radius:0 6px 0 0; flex-shrink:0;">
            <span style="font-family:'Clash Display',system-ui,sans-serif; font-weight:700; font-size:13px; color:#0D0D0D; line-height:1; margin-left:-1px;">SH</span>
          </div>
          <span style="font-family:'Clash Display',system-ui,sans-serif; font-weight:700; font-size:13px; color:#FF7136; letter-spacing:0.08em; text-transform:uppercase;">Supply</span>
          <span style="font-size:10px; color:#555; text-transform:uppercase; letter-spacing:0.12em; font-weight:500; margin-left:2px;">Admin</span>
        </a>
      </div>

      <!-- Nav -->
      <nav style="padding:16px 12px; flex:1; display:flex; flex-direction:column; gap:2px;">
        <a href="/admin"
           style={`display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:4px; text-decoration:none; font-size:13px; font-weight:500; letter-spacing:0.01em; transition:background 0.15s; ${activeNav === 'products' ? 'background:#1E1E1E; color:#F5F5F0;' : 'color:#888;'}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8L2 7h20l-6-4z"/>
          </svg>
          Products
        </a>
        <a href="/admin/links"
           style={`display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:4px; text-decoration:none; font-size:13px; font-weight:500; letter-spacing:0.01em; transition:background 0.15s; ${activeNav === 'links' ? 'background:#1E1E1E; color:#F5F5F0;' : 'color:#888;'}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          Payment Links
        </a>
        <a href="/admin/emails"
           style={`display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:4px; text-decoration:none; font-size:13px; font-weight:500; letter-spacing:0.01em; transition:background 0.15s; ${activeNav === 'emails' ? 'background:#1E1E1E; color:#F5F5F0;' : 'color:#888;'}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          Sent Emails
        </a>
        <a href="/admin/settings"
           style={`display:flex; align-items:center; gap:10px; padding:9px 10px; border-radius:4px; text-decoration:none; font-size:13px; font-weight:500; letter-spacing:0.01em; transition:background 0.15s; ${activeNav === 'settings' ? 'background:#1E1E1E; color:#F5F5F0;' : 'color:#888;'}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          Settings
        </a>
      </nav>

      <!-- Sign out -->
      <div style="padding:16px 12px; border-top:1px solid #1E1E1E;">
        <form method="POST" action="/api/admin/logout">
          <button type="submit"
                  style="display:flex; align-items:center; gap:10px; padding:9px 10px; width:100%; border:none; background:none; color:#555; font-size:13px; font-weight:500; cursor:pointer; border-radius:4px; transition:color 0.15s;"
                  onmouseover="this.style.color='#F5F5F0'" onmouseout="this.style.color='#555'">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Sign out
          </button>
        </form>
      </div>

    </aside>

    <!-- Main -->
    <main style="flex:1; min-height:100vh; overflow-x:hidden;">

      <!-- Top bar -->
      <div style="padding:28px 40px 0; border-bottom:1px solid #1E1E1E; padding-bottom:24px; display:flex; align-items:flex-end; justify-content:space-between;">
        <h1 style="font-family:'Clash Display',system-ui,sans-serif; font-weight:700; font-size:32px; text-transform:uppercase; letter-spacing:-0.02em; line-height:1; color:#F5F5F0;">{title}</h1>
        <slot name="actions" />
      </div>

      <!-- Content -->
      <div style="padding:32px 40px;">
        <slot />
      </div>

    </main>

  </body>
</html>
