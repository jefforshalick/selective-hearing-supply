---
interface Props {
  cartCount?: number;
}
const { cartCount = 0 } = Astro.props;
---

<nav class="h-[72px] flex items-center justify-between px-12 w-full border-b border-black/8 bg-[#F5F5F0]">

  <!-- Left: SH logo + SUPPLY wordmark -->
  <a href="/" class="flex items-center gap-2" aria-label="Selective Hearing Supply — home">
    <!-- SH badge -->
    <div class="flex items-center justify-start h-8 bg-[#0D0D0D] overflow-hidden shrink-0"
         style="width:41px; border-radius:0 8px 0 0;">
      <span class="text-[#F5F5F0] font-['Clash_Display',system-ui,sans-serif] font-bold text-2xl uppercase leading-none"
            style="margin-left:-3px;">SH</span>
    </div>
    <!-- SUPPLY wordmark -->
    <span class="text-[#FF7136] font-['Clash_Display',system-ui,sans-serif] font-bold text-2xl uppercase leading-none tracking-[-0.03em]">
      supply
    </span>
  </a>

  <!-- Right: cart icon -->
  <a href="/cart" class="relative flex items-center justify-center w-8 h-8 text-[#0D0D0D] hover:text-[#FF7136] transition-colors"
     aria-label="View cart">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
    {cartCount > 0 && (
      <span class="absolute -top-1 -right-1 w-4 h-4 bg-[#FF7136] text-[#F5F5F0] text-[9px] font-bold rounded-full flex items-center justify-center leading-none">
        {cartCount}
      </span>
    )}
  </a>

</nav>
