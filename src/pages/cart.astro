---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { products } from '../data/products';
---

<BaseLayout title="Cart">
  <Nav />

  <!-- Embed product data for client script to read -->
  <script type="application/json" id="product-data" set:html={JSON.stringify(products)} />

  <main class="min-h-[calc(100vh-72px)] bg-[#F5F5F0] px-6 lg:px-20 py-14">

    <h1 class="font-['Clash_Display',system-ui,sans-serif] font-bold text-[48px] uppercase leading-none tracking-[-0.02em] text-[#0D0D0D] mb-12">
      Cart
    </h1>

    <!-- Empty state -->
    <div id="cart-empty" class="flex flex-col items-start gap-6">
      <p class="text-[13px] text-[#666] font-['Helvetica_Neue',system-ui,sans-serif]">Your cart is empty.</p>
      <a href="/"
         class="inline-flex items-center px-7 py-3.5 bg-[#0D0D0D] text-[#F5F5F0] text-[10px] font-bold uppercase tracking-[0.15em] font-['Helvetica_Neue',system-ui,sans-serif] hover:opacity-80 transition-opacity"
         style="border-radius: 0 14px 0 0;">
        Browse Supply
      </a>
    </div>

    <!-- Cart items (hidden until JS populates) -->
    <div id="cart-filled" class="hidden flex-col gap-0">

      <!-- Line items -->
      <div id="cart-items" class="flex flex-col divide-y divide-[#D0CEC9] border-t border-[#D0CEC9]"></div>

      <!-- Totals -->
      <div class="flex flex-col items-end gap-6 mt-10 pt-8 border-t border-[#D0CEC9]">
        <div class="flex items-baseline gap-8">
          <span class="text-[11px] uppercase tracking-[0.14em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif]">Total</span>
          <span id="cart-total" class="text-[32px] font-bold tracking-[-0.02em] text-[#0D0D0D] font-['Helvetica_Neue',system-ui,sans-serif]">$0</span>
        </div>
        <button
          id="checkout-btn"
          class="inline-flex items-center gap-2 px-10 py-4 bg-[#FF7136] text-[#0D0D0D] text-[10px] font-bold uppercase tracking-[0.15em] font-['Helvetica_Neue',system-ui,sans-serif] cursor-pointer hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed"
          style="border-radius: 0 14px 0 0;">
          <span id="checkout-label">Checkout</span>
          <svg id="checkout-spinner" class="hidden animate-spin w-3.5 h-3.5" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="32" stroke-dashoffset="12"/>
          </svg>
        </button>
      </div>

    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#D0CEC9] px-6 lg:px-20 py-5 flex justify-end">
    <a href="https://selectivehear.ing"
       class="text-[11px] uppercase tracking-[0.14em] text-[#999] hover:text-[#0D0D0D] transition-colors font-['Helvetica_Neue',system-ui,sans-serif]">
      selectivehear.ing →
    </a>
  </footer>

  <script>
    const products = JSON.parse(document.getElementById('product-data')!.textContent!);
    const validIds = new Set(products.map((p: any) => p.id));

    // Prune any cart entries whose product no longer exists
    const rawCart: Record<string, number> = JSON.parse(localStorage.getItem('sh-supply-cart') || '{}');
    const cart: Record<string, number> = Object.fromEntries(
      Object.entries(rawCart).filter(([id]) => validIds.has(id))
    );
    if (Object.keys(cart).length !== Object.keys(rawCart).length) {
      localStorage.setItem('sh-supply-cart', JSON.stringify(cart));
      // Re-sync the nav badge after pruning
      const newCount = Object.values(cart).reduce((s: number, q: number) => s + q, 0);
      const badge = document.getElementById('cart-badge');
      if (badge) {
        if (newCount > 0) {
          badge.textContent = newCount > 9 ? '9+' : String(newCount);
          badge.classList.remove('hidden');
          badge.classList.add('flex');
        } else {
          badge.classList.add('hidden');
          badge.classList.remove('flex');
        }
      }
    }

    const keys = Object.keys(cart);

    if (keys.length > 0) {
      document.getElementById('cart-empty')!.style.display = 'none';
      const filled = document.getElementById('cart-filled')!;
      filled.classList.remove('hidden');
      filled.style.display = 'flex';

      const itemsEl = document.getElementById('cart-items')!;
      let total = 0;

      keys.forEach((id) => {
        const product = products.find((p: any) => p.id === id);
        if (!product || product.price === null) return;
        const qty = cart[id];
        const subtotal = product.price * qty;
        total += subtotal;

        const row = document.createElement('div');
        row.className = 'flex items-center justify-between py-6';
        row.innerHTML = `
          <div class="flex flex-col gap-1">
            <span class="font-['Clash_Display',system-ui,sans-serif] font-bold text-[20px] uppercase tracking-[-0.01em] text-[#0D0D0D]">${product.name}</span>
            <span class="text-[11px] uppercase tracking-[0.14em] text-[#FF7136] font-['Helvetica_Neue',system-ui,sans-serif]">${product.category}</span>
          </div>
          <div class="flex items-center gap-8">
            <div class="flex items-center gap-3">
              <button data-action="dec" data-id="${id}" class="w-7 h-7 flex items-center justify-center border border-[#D0CEC9] text-[#0D0D0D] text-sm hover:border-[#0D0D0D] transition-colors">−</button>
              <span class="w-6 text-center text-[14px] font-['Helvetica_Neue',system-ui,sans-serif]">${qty}</span>
              <button data-action="inc" data-id="${id}" class="w-7 h-7 flex items-center justify-center border border-[#D0CEC9] text-[#0D0D0D] text-sm hover:border-[#0D0D0D] transition-colors">+</button>
            </div>
            <span class="text-[20px] font-bold tracking-[-0.02em] text-[#0D0D0D] font-['Helvetica_Neue',system-ui,sans-serif] w-16 text-right">$${subtotal}</span>
            <button data-action="remove" data-id="${id}" class="text-[#999] hover:text-[#0D0D0D] transition-colors text-[18px] leading-none">×</button>
          </div>
        `;
        itemsEl.appendChild(row);
      });

      document.getElementById('cart-total')!.textContent = '$' + total;
    }

    // Qty / remove handlers (event delegation — no inline onclick)
    document.getElementById('cart-items')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!btn) return;
      const action = btn.dataset.action!;
      const id = btn.dataset.id!;
      const cart: Record<string, number> = JSON.parse(localStorage.getItem('sh-supply-cart') || '{}');

      if (action === 'inc') cart[id] = (cart[id] || 0) + 1;
      if (action === 'dec') { cart[id] = Math.max(0, (cart[id] || 0) - 1); if (cart[id] === 0) delete cart[id]; }
      if (action === 'remove') delete cart[id];

      localStorage.setItem('sh-supply-cart', JSON.stringify(cart));
      location.reload();
    });

    // Checkout
    document.getElementById('checkout-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('checkout-btn') as HTMLButtonElement;
      const label = document.getElementById('checkout-label')!;
      const spinner = document.getElementById('checkout-spinner')!;

      btn.disabled = true;
      label.textContent = 'Redirecting…';
      spinner.classList.remove('hidden');

      try {
        const cart = JSON.parse(localStorage.getItem('sh-supply-cart') || '{}');
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ cart }),
        });

        const data = await res.json();
        if (!res.ok || !data.url) throw new Error(data.error || 'Checkout failed');

        window.location.href = data.url;
      } catch (err: any) {
        label.textContent = 'Checkout';
        spinner.classList.add('hidden');
        btn.disabled = false;
        alert('Something went wrong: ' + err.message);
      }
    });
  </script>
</BaseLayout>
