---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { products } from '../data/products';
---

<BaseLayout>
  <Nav />

  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <section class="bg-[#FF7136] overflow-hidden
                  flex flex-col px-6 py-10
                  lg:flex-row lg:items-center lg:justify-between lg:px-20 lg:py-14 lg:gap-16">

    <!-- Text block -->
    <div class="flex flex-col gap-4 lg:gap-5 shrink-0">

      <!-- Top drop label — ghost (same orange as bg) -->
      <div class="hidden lg:flex items-center gap-3">
        <span class="w-6 h-[2px] bg-[#FF7136] shrink-0"></span>
        <span class="text-[11px] font-medium uppercase tracking-[0.2em] text-[#FF7136] font-['Helvetica_Neue',system-ui,sans-serif]">
          Drop 001 — April 2026
        </span>
      </div>

      <!-- Headline -->
      <div>
        <div class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase leading-[0.9] tracking-[-0.02em] text-[#0D0D0D]
                    text-[clamp(52px,13vw,72px)] lg:text-[72px]">Selective</div>
        <div class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase leading-[0.9] tracking-[-0.02em] text-[#0D0D0D]
                    text-[clamp(52px,13vw,72px)] lg:text-[72px]">Hearing</div>
        <div class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase leading-[0.9] tracking-[-0.02em] text-[#F5F5F0]
                    text-[clamp(52px,13vw,72px)] lg:text-[72px]">Supply</div>
      </div>

      <!-- Items for sale -->
      <div class="flex items-center gap-3 mt-1">
        <span class="w-6 h-[2px] bg-[#F5F5F0] shrink-0"></span>
        <span class="text-[11px] font-medium uppercase tracking-[0.2em] text-[#F5F5F0] font-['Helvetica_Neue',system-ui,sans-serif]">
          Items for sale
        </span>
      </div>
    </div>

    <!-- Ears — hidden mobile, visible lg+ -->
    <img src="/images/ears/ear-drip-1.svg" alt="" aria-hidden="true"
         class="hidden lg:block shrink-0"
         style="width:115.5px; height:251px; object-fit:contain;" />
    <img src="/images/ears/ear-drip-2.svg" alt="" aria-hidden="true"
         class="hidden lg:block shrink-0"
         style="width:125.5px; height:261px; object-fit:contain;" />
    <img src="/images/ears/ear-drip-3.svg" alt="" aria-hidden="true"
         class="hidden lg:block shrink-0"
         style="width:202px; height:261px; object-fit:contain;" />
  </section>

  <!-- ─── Product grid ──────────────────────────────────────────────────── -->
  <section class="bg-[#F5F5F0]">
    <!--
      flex-wrap below lg  → cards reflow 2-col then 1-col based on available space
      flex-nowrap at lg+  → fixed 3-col with explicit 1px vertical dividers
    -->
    <div class="flex flex-wrap lg:flex-nowrap lg:items-stretch
                px-6 py-10 lg:px-20 lg:pt-14 lg:pb-20"
         style="gap: 32px;">

      {products.map((product, i) => (
        <>
          {/* Vertical divider — between cards, lg+ only */}
          {i > 0 && (
            <div class="hidden lg:block w-px self-stretch bg-[#D8D5CF] shrink-0"></div>
          )}

          {/* Card */}
          <div class="product-card flex flex-col" style="min-width: 0;">

            {/* Image / placeholder */}
            {product.status === 'coming_soon' ? (
              <div class="product-img w-full mb-6 flex items-center justify-center"
                   style="border: 2px dashed #D0CEC9;">
                <span class="text-[11px] uppercase tracking-[0.2em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif] text-center leading-relaxed">
                  Coming<br/>Soon
                </span>
              </div>
            ) : (
              <div class="product-img w-full mb-6 bg-[#0D0D0D] relative overflow-hidden flex items-center justify-center">
                {product.image ? (
                  <img src={product.image} alt={product.name} class="w-full h-full object-cover" />
                ) : (
                  <div class="flex flex-col items-center gap-2.5 opacity-40">
                    <span class="w-8 h-px bg-[#FF7136]"></span>
                    <span class="text-[10px] uppercase tracking-[0.2em] text-[#F5F5F0] font-['Helvetica_Neue',system-ui,sans-serif]">Image</span>
                  </div>
                )}
                <span class="absolute top-5 left-5 bg-[#FF7136] text-[#0D0D0D] text-[10px] font-bold uppercase tracking-[0.12em] font-['Helvetica_Neue',system-ui,sans-serif]"
                      style="padding: 5px 10px;">
                  In Stock
                </span>
              </div>
            )}

            {/* Category + price */}
            <div class="flex items-start justify-between mb-1.5">
              <span class={`text-[10px] font-medium uppercase tracking-[0.18em] font-['Helvetica_Neue',system-ui,sans-serif] leading-3 ${product.status === 'coming_soon' ? 'text-[#C0BDB7]' : 'text-[#FF7136]'}`}>
                {product.category}
              </span>
              <span class={`text-[22px] font-bold tracking-[-0.02em] font-['Helvetica_Neue',system-ui,sans-serif] leading-7 ${product.status === 'coming_soon' ? 'text-[#C0BDB7]' : 'text-[#0D0D0D]'}`}>
                {product.price !== null ? `$${product.price}` : '—'}
              </span>
            </div>

            {/* Product name */}
            <h2 class={`font-['Clash_Display',system-ui,sans-serif] font-bold text-[26px] uppercase leading-[1.05] tracking-[-0.01em] mb-3 ${product.status === 'coming_soon' ? 'text-[#C0BDB7]' : 'text-[#0D0D0D]'}`}>
              {product.name}
            </h2>

            {/* Description — flex-grow pins CTA to same baseline */}
            <p class={`flex-grow text-[13px] leading-[1.6] mb-6 font-['Helvetica_Neue',system-ui,sans-serif] ${product.status === 'coming_soon' ? 'text-[#C0BDB7]' : 'text-[#666]'}`}>
              {product.description}
            </p>

            {/* CTA */}
            <div class="flex items-center gap-4">
              {product.status === 'in_stock' && (
                <>
                  <button
                    class="inline-flex items-center bg-[#FF7136] text-[#0D0D0D] text-[10px] font-bold uppercase tracking-[0.15em] font-['Helvetica_Neue',system-ui,sans-serif] cursor-pointer transition-opacity hover:opacity-80"
                    style="padding: 14px 28px; border-radius: 0 14px 0 0;"
                    data-product-id={product.id}
                    data-product-price={product.price}
                  >
                    Add to Cart
                  </button>
                  {product.stock !== null && (
                    <span class="text-[11px] uppercase tracking-[0.1em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif]">
                      {product.stock} left
                    </span>
                  )}
                </>
              )}
              {product.status === 'coming_soon' && (
                <button
                  class="inline-flex items-center text-[10px] font-bold uppercase tracking-[0.15em] text-[#0D0D0D] font-['Helvetica_Neue',system-ui,sans-serif] cursor-pointer hover:border-[#0D0D0D] transition-colors"
                  style="padding: 14px 28px; border-radius: 0 14px 0 0; border: 1.5px solid #D0CEC9;"
                >
                  Notify Me
                </button>
              )}
            </div>

          </div>
        </>
      ))}
    </div>
  </section>

  <!-- ─── Footer ────────────────────────────────────────────────────────── -->
  <footer class="border-t border-[#D0CEC9] bg-[#F5F5F0] flex justify-end px-6 py-5 lg:px-20">
    <a href="https://selectivehear.ing"
       class="text-[11px] uppercase tracking-[0.14em] text-[#999] hover:text-[#0D0D0D] transition-colors font-['Helvetica_Neue',system-ui,sans-serif]">
      selectivehear.ing →
    </a>
  </footer>
</BaseLayout>

<style>
  /* Image panel height */
  .product-img { height: 220px; }
  @media (min-width: 1024px) {
    .product-img { height: 296px; }
  }

  /*
    Card widths:
    - Default (mobile ≥480px): exactly half-width so 3rd card stays same
      size as its siblings with empty space to the right.
    - Small mobile (<480px): full width, 1-col stack.
    - lg+ (1024px): flex-1, equal thirds (3-col with dividers).
  */
  .product-card {
    flex: 0 0 calc(50% - 16px); /* 2 × (50% - 16px) + 32px gap = 100% */
  }
  @media (max-width: 479px) {
    .product-card {
      flex: 0 0 100%;
    }
  }
  @media (min-width: 1024px) {
    .product-card {
      flex: 1 1 0%;
    }
  }

  /* Horizontal separators only at 2-col and 1-col (below lg) */
  @media (max-width: 1023px) {
    .product-card:not(:last-child) {
      padding-bottom: 32px;
      border-bottom: 1px solid #D8D5CF;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-product-id]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.productId!;
      const price = Number((btn as HTMLElement).dataset.productPrice);
      const cart: Record<string, number> = JSON.parse(localStorage.getItem('sh-supply-cart') || '{}');
      cart[id] = (cart[id] || 0) + 1;
      localStorage.setItem('sh-supply-cart', JSON.stringify(cart));
      btn.textContent = 'Added ✓';
      setTimeout(() => { btn.textContent = 'Add to Cart'; }, 1200);
    });
  });
</script>
