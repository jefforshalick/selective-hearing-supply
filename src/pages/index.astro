---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getProducts } from '../lib/products';

const products = await getProducts();
---

<BaseLayout>
  <Nav />

  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <!--
    Ears are always flex children. overflow:hidden clips them as viewport narrows.
    gap between text and ears shrinks at smaller widths, pushing ears further right.
    At ≥1024px all three fully visible; below that they clip progressively.
  -->
  <section class="bg-[#FF7136] overflow-hidden relative flex items-center"
           id="hero-section">

    <!-- Text block -->
    <div class="flex flex-col shrink-0" style="gap: 16px;">
      <!-- Top drop label — ghost (same orange as bg, lg only) -->
      <div class="hidden lg:flex items-center" style="gap: 12px;">
        <span style="width:24px; height:2px; background:#FF7136; flex-shrink:0;"></span>
        <span class="font-['Helvetica_Neue',system-ui,sans-serif] font-medium uppercase text-[#FF7136]" style="font-size:11px; letter-spacing:0.2em;">Drop 001 — April 2026</span>
      </div>
      <!-- Headline -->
      <div>
        <div class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase text-[#0D0D0D]"
             style="font-size: clamp(52px, 13vw, 72px); line-height: 0.9; letter-spacing: -0.02em;">Selective</div>
        <div class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase text-[#0D0D0D]"
             style="font-size: clamp(52px, 13vw, 72px); line-height: 0.9; letter-spacing: -0.02em;">Hearing</div>
        <div class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase text-[#F5F5F0]"
             style="font-size: clamp(52px, 13vw, 72px); line-height: 0.9; letter-spacing: -0.02em;">Supply</div>
      </div>
      <!-- Items for sale -->
      <div class="flex items-center" style="gap: 12px;">
        <span style="width:24px; height:2px; background:#F5F5F0; flex-shrink:0;"></span>
        <span class="font-['Helvetica_Neue',system-ui,sans-serif] font-medium uppercase text-[#F5F5F0]" style="font-size:11px; letter-spacing:0.2em;">Items for sale</span>
      </div>
    </div>

    <!-- Ears: always flex children, gap:64px between them, clipped by overflow:hidden -->
    <div id="ears" aria-hidden="true">
      <img src="/images/ears/ear-drip-1.svg" alt="" style="width:115.5px; height:251px; object-fit:contain; flex-shrink:0;" />
      <img src="/images/ears/ear-drip-2.svg" alt="" style="width:125.5px; height:261px; object-fit:contain; flex-shrink:0;" />
      <img src="/images/ears/ear-drip-3.svg" alt="" style="width:202px; height:261px; object-fit:contain; flex-shrink:0;" />
    </div>

  </section>

  <style>
    #hero-section {
      height: 375px;
      padding: 40px 24px;
      gap: 68px; /* tight gap at small widths — ears clip more */
    }
    #ears {
      display: flex;
      align-items: center;
      gap: 64px;
    }
    @media (min-width: 600px) {
      #hero-section { gap: 104px; } /* more breathing room, fewer ears visible */
    }
    @media (min-width: 1024px) {
      #hero-section { padding: 40px 56px; gap: 104px; }
    }
    @media (min-width: 1189px) {
      #ears { margin-left: auto; }
    }
  </style>

  <!-- ─── Product grid ──────────────────────────────────────────────────── -->
  <section class="bg-[#F5F5F0]">
    {products.length === 0 ? (
      <div class="flex flex-col items-center justify-center px-6 py-24 lg:py-40 text-center">
        <h2 class="font-['Clash_Display',system-ui,sans-serif] font-bold uppercase text-[#0D0D0D] mb-4"
            style="font-size: clamp(36px, 8vw, 56px); line-height: 0.95; letter-spacing: -0.02em;">
          Coming<br/>Soon
        </h2>
        <p class="text-[13px] text-[#999] leading-relaxed font-['Helvetica_Neue',system-ui,sans-serif] max-w-xs mt-4">
          Products are on the way. Check back soon.
        </p>
      </div>
    ) : (
    <!--
      flex-wrap below lg  → cards reflow 2-col then 1-col based on available space
      flex-nowrap at lg+  → fixed 3-col with explicit 1px vertical dividers
    -->
    <div class="flex flex-wrap lg:flex-nowrap lg:items-stretch
                px-6 py-10 lg:px-20 lg:pt-14 lg:pb-20"
         style="gap: 32px;">

      {products.map((product, i) => (
        <>
          {/* Vertical divider — between cards, lg+ only */}
          {i > 0 && (
            <div class="hidden lg:block w-px self-stretch bg-[#D8D5CF] shrink-0"></div>
          )}

          {/* Card */}
          <div class="product-card flex flex-col" style="min-width: 0;">

            {/* Image / placeholder */}
            <div class="product-img w-full mb-6 relative overflow-hidden flex items-center justify-center"
                 style={product.status === 'coming_soon' && !product.image ? 'border: 2px dashed #C4C2BC; background: #ECEAE6;' : 'background: #0D0D0D;'}>
              {product.image ? (
                <img src={product.image} alt={product.name} class="w-full h-full object-cover" />
              ) : product.status === 'coming_soon' ? (
                <span class="text-[11px] uppercase tracking-[0.2em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif] text-center leading-relaxed">
                  Coming Soon<br/>Image
                </span>
              ) : (
                <div class="flex flex-col items-center gap-2.5 opacity-40">
                  <span class="w-8 h-px bg-[#FF7136]"></span>
                  <span class="text-[10px] uppercase tracking-[0.2em] text-[#F5F5F0] font-['Helvetica_Neue',system-ui,sans-serif]">Image</span>
                </div>
              )}
            </div>

            {/* Category + price */}
            <div class="flex items-start justify-between mb-1.5">
              <span class={`text-[10px] font-medium uppercase tracking-[0.18em] font-['Helvetica_Neue',system-ui,sans-serif] leading-3 ${product.status !== 'coming_soon' ? 'text-[#FF7136]' : 'text-[#C0BDB7]'}`}>
                {product.category}
              </span>
              <span class={`text-[22px] font-bold tracking-[-0.02em] font-['Helvetica_Neue',system-ui,sans-serif] leading-7 ${product.status !== 'coming_soon' ? 'text-[#0D0D0D]' : 'text-[#C0BDB7]'}`}>
                {product.price !== null ? `$${product.price}` : '—'}
              </span>
            </div>

            {/* Product name */}
            <h2 class={`font-['Clash_Display',system-ui,sans-serif] font-bold text-[26px] uppercase leading-[1.05] tracking-[-0.01em] mb-3 ${product.status !== 'coming_soon' ? 'text-[#0D0D0D]' : 'text-[#C0BDB7]'}`}>
              {product.name}
            </h2>

            {/* Description — flex-grow pins CTA to same baseline */}
            <p class={`flex-grow text-[13px] leading-[1.6] mb-6 font-['Helvetica_Neue',system-ui,sans-serif] ${product.status !== 'coming_soon' ? 'text-[#666]' : 'text-[#C0BDB7]'}`}>
              {product.description}
            </p>

            {/* CTA */}
            <div class="flex items-center gap-4">
              {product.status === 'in_stock' && (
                <>
                  <button
                    class="inline-flex items-center bg-[#FF7136] text-[#0D0D0D] text-[10px] font-bold uppercase tracking-[0.15em] font-['Helvetica_Neue',system-ui,sans-serif] cursor-pointer transition-opacity hover:opacity-80"
                    style="padding: 14px 28px; border-radius: 0 14px 0 0;"
                    data-product-id={product.id}
                    data-product-price={product.price}
                  >
                    Add to Cart
                  </button>
                  {product.stock !== null && (
                    <span class="text-[11px] uppercase tracking-[0.1em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif]">
                      {product.stock} left
                    </span>
                  )}
                </>
              )}
              {product.status === 'sold_out' && (
                <>
                  <button
                    disabled
                    class="inline-flex items-center text-[10px] font-bold uppercase tracking-[0.15em] text-[#B0ADA8] font-['Helvetica_Neue',system-ui,sans-serif] cursor-not-allowed"
                    style="padding: 14px 28px; border-radius: 0 14px 0 0; background: #D8D5CF;"
                  >
                    Add to Cart
                  </button>
                  <span class="text-[11px] uppercase tracking-[0.1em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif]">
                    0 Left
                  </span>
                </>
              )}
              {product.status === 'coming_soon' && (
                <>
                  <button
                    disabled
                    class="inline-flex items-center text-[10px] font-bold uppercase tracking-[0.15em] text-[#B0ADA8] font-['Helvetica_Neue',system-ui,sans-serif] cursor-not-allowed"
                    style="padding: 14px 28px; border-radius: 0 14px 0 0; background: #D8D5CF;"
                  >
                    Add to Cart
                  </button>
                  <span class="text-[11px] uppercase tracking-[0.1em] text-[#999] font-['Helvetica_Neue',system-ui,sans-serif]">
                    Coming Soon
                  </span>
                </>
              )}
            </div>

          </div>
        </>
      ))}
    </div>
    )}
  </section>

  <!-- ─── Footer ────────────────────────────────────────────────────────── -->
  <footer class="border-t border-[#D0CEC9] bg-[#F5F5F0] flex justify-end px-6 py-5 lg:px-20">
    <a href="https://selectivehear.ing"
       class="text-[11px] uppercase tracking-[0.14em] text-[#999] hover:text-[#0D0D0D] transition-colors font-['Helvetica_Neue',system-ui,sans-serif]">
      selectivehear.ing →
    </a>
  </footer>
</BaseLayout>

<style>
  /* Image panel height */
  .product-img { height: 220px; }
  @media (min-width: 1024px) {
    .product-img { height: 296px; }
  }

  /*
    Card widths:
    - Default (mobile ≥480px): exactly half-width so 3rd card stays same
      size as its siblings with empty space to the right.
    - Small mobile (<480px): full width, 1-col stack.
    - lg+ (1024px): flex-1, equal thirds (3-col with dividers).
  */
  .product-card {
    flex: 0 0 calc(50% - 16px); /* 2 × (50% - 16px) + 32px gap = 100% */
  }
  @media (max-width: 479px) {
    .product-card {
      flex: 0 0 100%;
    }
  }
  @media (min-width: 1024px) {
    .product-card {
      flex: 1 1 0%;
      max-width: calc(33.333% - 2px); /* never wider than one column regardless of item count */
    }
  }

  /* Horizontal separators only at 2-col and 1-col (below lg) */
  @media (max-width: 1023px) {
    .product-card:not(:last-child) {
      padding-bottom: 32px;
      border-bottom: 1px solid #D8D5CF;
    }
  }
</style>

<script is:inline>
  function updateCartBadge(cart) {
    var count = Object.values(cart).reduce(function(s, q) { return s + q; }, 0);
    var badge = document.getElementById('cart-badge');
    if (!badge) return;
    if (count > 0) {
      badge.textContent = count > 9 ? '9+' : count;
      badge.classList.remove('hidden');
      badge.classList.add('flex');
    } else {
      badge.classList.add('hidden');
      badge.classList.remove('flex');
    }
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-product-id]');
    if (!btn) return;
    var id = btn.dataset.productId;
    if (!id) return;
    var cart = JSON.parse(localStorage.getItem('sh-supply-cart') || '{}');
    cart[id] = (cart[id] || 0) + 1;
    localStorage.setItem('sh-supply-cart', JSON.stringify(cart));
    updateCartBadge(cart);
    btn.textContent = 'Added ✓';
    setTimeout(function() { btn.textContent = 'Add to Cart'; }, 1200);
  });
</script>
