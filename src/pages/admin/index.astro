---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getProducts, upsertProduct } from '../../lib/products';
import { syncProductToStripe } from '../../lib/stripe';

let syncError = '';
let syncCount = 0;

if (Astro.request.method === 'POST') {
  const allProducts = await getProducts();
  for (const product of allProducts) {
    if (!product.stripe_product_id) {
      try {
        const ids = await syncProductToStripe(product);
        product.stripe_product_id = ids.stripe_product_id;
        product.stripe_price_id = ids.stripe_price_id;
        await upsertProduct(product);
        syncCount++;
      } catch (e: any) {
        syncError = `Failed on "${product.name}": ${e.message}`;
        break;
      }
    }
  }
}

const products = await getProducts();

const statusLabel: Record<string, string> = {
  in_stock: 'In Stock',
  sold_out: 'Sold Out',
  coming_soon: 'Coming Soon',
};
const statusColor: Record<string, string> = {
  in_stock: '#FF7136',
  sold_out: '#666',
  coming_soon: '#888',
};
---

<AdminLayout title="Products" activeNav="products">

  <div slot="actions" style="display:flex; align-items:center; gap:10px;">
    {products.some(p => !p.stripe_product_id) && (
      <form method="POST">
        <button type="submit"
                style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; padding:11px 20px; color:#888; background:none; border:1px solid #2A2A2A; cursor:pointer; transition:all 0.15s;"
                onmouseover="this.style.color='#F5F5F0';this.style.borderColor='#555'" onmouseout="this.style.color='#888';this.style.borderColor='#2A2A2A'">
          Sync All to Stripe
        </button>
      </form>
    )}
    <a href="/admin/product/new"
       style="display:inline-flex; align-items:center; gap:8px; background:#FF7136; color:#0D0D0D; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; padding:11px 22px; text-decoration:none; border-radius:0 10px 0 0; transition:opacity 0.15s;"
       onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Product
    </a>
  </div>

  {syncCount > 0 && (
    <p style="font-size:12px; color:#4CAF50; margin-bottom:16px;">Synced {syncCount} product{syncCount !== 1 ? 's' : ''} to Stripe.</p>
  )}
  {syncError && (
    <p style="font-size:12px; color:#FF7136; margin-bottom:16px;">{syncError}</p>
  )}

  {products.length === 0 ? (
    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding:80px 0; gap:16px;">
      <p style="color:#555; font-size:14px;">No products yet.</p>
      <a href="/admin/product/new" style="color:#FF7136; font-size:12px; text-decoration:underline; text-underline-offset:3px;">Add your first product →</a>
    </div>
  ) : (
    <div style="border:1px solid #2A2A2A; overflow:hidden;">

      <!-- Table header -->
      <div style="display:grid; grid-template-columns:32px 1fr 100px 80px 120px 80px 80px; gap:0; padding:10px 20px; background:#141414; border-bottom:1px solid #2A2A2A;">
        <span></span>
        {['Product', 'Price', 'Stock', 'Status', 'Stripe', ''].map((h, i) => (
          <span style={`font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:#555; font-weight:500;${i === 4 ? ' text-align:center;' : ''}`}>{h}</span>
        ))}
      </div>

      <!-- Rows -->
      <div id="product-list">
      {products.map((product, i) => (
        <div data-id={product.id} draggable="true"
             style={`display:grid; grid-template-columns:32px 1fr 100px 80px 120px 80px 80px; align-items:center; gap:0; padding:16px 20px; ${i < products.length - 1 ? 'border-bottom:1px solid #1E1E1E;' : ''} transition:background 0.12s; cursor:default;`}
             onmouseover="this.style.background='#111'" onmouseout="this.style.background='transparent'">

          <!-- Drag handle -->
          <div class="drag-handle" style="cursor:grab; color:#333; display:flex; align-items:center; user-select:none;"
               title="Drag to reorder">
            <svg width="12" height="16" viewBox="0 0 12 16" fill="currentColor">
              <circle cx="4" cy="3" r="1.5"/><circle cx="8" cy="3" r="1.5"/>
              <circle cx="4" cy="8" r="1.5"/><circle cx="8" cy="8" r="1.5"/>
              <circle cx="4" cy="13" r="1.5"/><circle cx="8" cy="13" r="1.5"/>
            </svg>
          </div>

          <!-- Name + category -->
          <div style="display:flex; flex-direction:column; gap:3px;">
            <span style="font-family:'Clash Display',system-ui,sans-serif; font-weight:700; font-size:16px; text-transform:uppercase; letter-spacing:-0.01em; color:#F5F5F0;">{product.name}</span>
            <span style="font-size:10px; text-transform:uppercase; letter-spacing:0.14em; color:#555;">{product.category}</span>
          </div>

          <!-- Price -->
          <span style="font-size:15px; font-weight:700; color:#F5F5F0; letter-spacing:-0.01em;">
            {product.price !== null ? `$${product.price}` : '—'}
          </span>

          <!-- Stock -->
          <span style={`font-size:14px; font-weight:500; ${product.stock !== null && product.stock > 0 ? 'color:#F5F5F0;' : 'color:#555;'}`}>
            {product.stock !== null ? product.stock : '—'}
          </span>

          <!-- Status -->
          <span style={`display:inline-flex; align-items:center; gap:5px; font-size:10px; text-transform:uppercase; letter-spacing:0.12em; font-weight:600; color:${statusColor[product.status]};`}>
            <span style={`width:5px; height:5px; border-radius:50%; background:${statusColor[product.status]}; flex-shrink:0;`}></span>
            {statusLabel[product.status]}
          </span>

          <!-- Stripe sync status -->
          <span style="display:flex; justify-content:center;" title={product.stripe_product_id ? 'Synced to Stripe' : 'Not synced'}>
            <span style={`width:8px; height:8px; border-radius:50%; background:${product.stripe_product_id ? '#4CAF50' : '#333'}; display:inline-block;`}></span>
          </span>

          <!-- Actions -->
          <div style="display:flex; align-items:center; gap:8px; justify-content:flex-end;">
            <a href={`/admin/product/${product.id}`}
               style="font-size:11px; color:#888; text-decoration:none; padding:5px 10px; border:1px solid #2A2A2A; transition:all 0.15s;"
               onmouseover="this.style.borderColor='#FF7136';this.style.color='#FF7136'" onmouseout="this.style.borderColor='#2A2A2A';this.style.color='#888'">
              Edit
            </a>
          </div>

        </div>
      ))}
      </div>
    </div>
  )}

<script>
  const list = document.getElementById('product-list');
  if (list) {
    let dragging: HTMLElement | null = null;

    list.addEventListener('dragstart', (e) => {
      const row = (e.target as HTMLElement).closest('[data-id]') as HTMLElement;
      if (!row) return;
      dragging = row;
      setTimeout(() => row.style.opacity = '0.4', 0);
    });

    list.addEventListener('dragend', () => {
      if (dragging) dragging.style.opacity = '1';
      dragging = null;
      list.querySelectorAll('[data-id]').forEach(r => (r as HTMLElement).style.borderTop = '');
    });

    list.addEventListener('dragover', (e) => {
      e.preventDefault();
      const row = (e.target as HTMLElement).closest('[data-id]') as HTMLElement;
      if (!row || row === dragging) return;
      const rect = row.getBoundingClientRect();
      const after = (e as DragEvent).clientY > rect.top + rect.height / 2;
      list.querySelectorAll('[data-id]').forEach(r => (r as HTMLElement).style.borderTop = '');
      if (!after) row.style.borderTop = '2px solid #FF7136';
      else (row.nextElementSibling as HTMLElement | null)?.style && ((row.nextElementSibling as HTMLElement).style.borderTop = '2px solid #FF7136');
    });

    list.addEventListener('drop', async (e) => {
      e.preventDefault();
      const target = (e.target as HTMLElement).closest('[data-id]') as HTMLElement;
      if (!target || !dragging || target === dragging) return;
      const rect = target.getBoundingClientRect();
      const after = (e as DragEvent).clientY > rect.top + rect.height / 2;
      if (after) target.after(dragging);
      else target.before(dragging);

      const ids = Array.from(list.querySelectorAll('[data-id]')).map(r => r.getAttribute('data-id')!);
      await fetch('/api/admin/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
      });
    });
  }
</script>

</AdminLayout>
