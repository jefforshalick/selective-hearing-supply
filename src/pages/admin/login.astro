---
export const prerender = false;
import { verifyPassword, COOKIE_NAME } from '../../lib/auth';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password')?.toString() ?? '';
  const token = await verifyPassword(password);
  if (token) {
    Astro.cookies.set(COOKIE_NAME, token, {
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 7, // 7 days
      path: '/',
    });
    return Astro.redirect('/admin');
  }
  error = 'Incorrect password.';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — SH Supply</title>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@700&display=swap" />
    <meta name="robots" content="noindex,nofollow" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #0D0D0D; color: #F5F5F0; font-family: 'Helvetica Neue', system-ui, sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    </style>
  </head>
  <body>
    <div style="width:100%; max-width:380px; padding:0 24px;">

      <!-- Logo -->
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:48px;">
        <div style="width:36px; height:32px; background:#FF7136; display:flex; align-items:center; justify-content:center; border-radius:0 8px 0 0; flex-shrink:0;">
          <span style="font-family:'Clash Display',system-ui,sans-serif; font-weight:700; font-size:15px; color:#0D0D0D; line-height:1; margin-left:-1px;">SH</span>
        </div>
        <div>
          <div style="font-family:'Clash Display',system-ui,sans-serif; font-weight:700; font-size:16px; color:#FF7136; letter-spacing:0.06em; text-transform:uppercase; line-height:1;">Supply</div>
          <div style="font-size:10px; color:#555; text-transform:uppercase; letter-spacing:0.14em; font-weight:500; margin-top:2px;">Admin</div>
        </div>
      </div>

      <!-- Form -->
      <form method="POST" style="display:flex; flex-direction:column; gap:20px;">
        <div style="display:flex; flex-direction:column; gap:8px;">
          <label style="font-size:10px; text-transform:uppercase; letter-spacing:0.16em; color:#666; font-weight:500;">Password</label>
          <input
            type="password"
            name="password"
            autofocus
            required
            style="background:#141414; border:1px solid #2A2A2A; color:#F5F5F0; font-size:14px; padding:12px 14px; outline:none; width:100%; transition:border-color 0.15s;"
            onfocus="this.style.borderColor='#FF7136'" onblur="this.style.borderColor='#2A2A2A'"
          />
        </div>

        {error && (
          <p style="font-size:12px; color:#FF7136; margin-top:-8px;">{error}</p>
        )}

        <button
          type="submit"
          style="background:#FF7136; color:#0D0D0D; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.15em; padding:14px 28px; border:none; cursor:pointer; border-radius:0 10px 0 0; transition:opacity 0.15s; text-align:center;"
          onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          Sign In
        </button>
      </form>

    </div>
  </body>
</html>
